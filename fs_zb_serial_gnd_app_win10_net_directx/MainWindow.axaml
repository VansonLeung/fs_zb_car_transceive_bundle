<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RCCarController.MainWindow"
        Title="RC Car Controller"
        Width="760" Height="480"
        FontSize="11"
        WindowStartupLocation="CenterScreen">
    <TabControl>
        <TabItem Header="Drive">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10"
                        RowDefinitions="Auto,Auto,Auto,Auto">
                    <!-- Steering + Throttle -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Steering (0-180)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider x:Name="SteeringSlider" Minimum="0" Maximum="180" Value="90" Width="200"/>
                                <NumericUpDown x:Name="SteeringNumeric" Minimum="0" Maximum="180" Value="90" Width="110"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Throttle (0-180)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider x:Name="ThrottleSlider" Minimum="0" Maximum="180" Value="90" Width="200"/>
                                <NumericUpDown x:Name="ThrottleNumeric" Minimum="0" Maximum="180" Value="90" Width="110"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Driving + WebSocket section -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Driving Mode" FontWeight="Bold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <CheckBox x:Name="DrivingModeToggle" Content="Driving Mode"/>
                                <TextBlock Text="Steering Offset:" VerticalAlignment="Center"/>
                                <NumericUpDown x:Name="SteeringOffsetNumeric" Minimum="-50" Maximum="50" Value="0" Width="110"/>
                                <TextBlock x:Name="SteeringOffsetLabel" Text="(0)" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="WebSocket Input" FontWeight="Bold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,4">
                                <CheckBox x:Name="WebSocketToggle" Content="Enable WebSocket client" IsChecked="True"/>
                                <TextBlock x:Name="WebSocketStatusLabel" Text="WebSocket: Initializing" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <CheckBox x:Name="ReverseSteeringToggle" Content="Reverse Steering"/>
                                <CheckBox x:Name="ReverseThrottleToggle" Content="Reverse Throttle"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Output limiting and mapping -->
                    <Grid Grid.Row="2" ColumnDefinitions="*" Margin="0,6,0,6">
                        <StackPanel>
                            <TextBlock Text="Rate Limit (per tick)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Steering step max" VerticalAlignment="Center"/>
                                <NumericUpDown x:Name="SteeringStepLimitNumeric" Minimum="1" Maximum="180" Value="180" Width="110"/>
                                <TextBlock Text="Throttle step max" VerticalAlignment="Center"/>
                                <NumericUpDown x:Name="ThrottleStepLimitNumeric" Minimum="1" Maximum="180" Value="180" Width="110"/>
                            </StackPanel>
                            <TextBlock Text="Limits how much each command can change." FontStyle="Italic" FontSize="11"/>
                        </StackPanel>
                    </Grid>

                    <!-- Serial Port Controls -->
                    <Border Grid.Row="3" Padding="10" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Serial Connection" FontWeight="Bold" Margin="0,0,0,6"/>
                            <WrapPanel Margin="0,0,0,4">
                                <TextBlock Text="Port:" VerticalAlignment="Center"/>
                                <ComboBox x:Name="PortComboBox" Width="120"/>
                                <TextBlock Text="Baud:" VerticalAlignment="Center"/>
                                <ComboBox x:Name="BaudComboBox" Width="100">
                                    <ComboBoxItem>9600</ComboBoxItem>
                                    <ComboBoxItem>19200</ComboBoxItem>
                                    <ComboBoxItem>38400</ComboBoxItem>
                                    <ComboBoxItem>57600</ComboBoxItem>
                                    <ComboBoxItem IsSelected="True">115200</ComboBoxItem>
                                </ComboBox>
                                <Button x:Name="RefreshButton" Content="Refresh" MinWidth="70"/>
                                <Button x:Name="ConnectButton" Content="Connect" MinWidth="90"/>
                                <TextBlock x:Name="StatusLabel" Text="Disconnected" Foreground="Red" VerticalAlignment="Center"/>
                            </WrapPanel>
                            <CheckBox x:Name="AutoConnectToggle" Content="Auto-connect serial every 10 seconds" Margin="0,2,0,6"/>
                            <TextBlock x:Name="LatestMessageLabel" Text="Latest: (not connected)" FontWeight="Bold" FontFamily="Consolas" FontSize="12"/>
                            <TextBlock x:Name="LatestAckLabel" Text="Ack: (waiting)" FontWeight="Bold" FontFamily="Consolas" FontSize="12" Foreground="Green"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="MAC Manager">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Text="Configure MAC index range (0-255). Ground derives MACs automatically." FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                        <TextBlock Text="Start Index" VerticalAlignment="Center"/>
                        <NumericUpDown x:Name="StartIndexNumeric" Minimum="0" Maximum="255" Width="110"/>
                        <TextBlock Text="End Index" VerticalAlignment="Center"/>
                        <NumericUpDown x:Name="EndIndexNumeric" Minimum="0" Maximum="255" Width="110"/>
                        <Button x:Name="ApplyRangeButton" Content="Apply Range" Width="120"/>
                        <Button x:Name="RequestActiveMacButton" Content="Refresh Active" Width="130"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                        <TextBlock Text="Active Index" VerticalAlignment="Center"/>
                        <NumericUpDown x:Name="ActiveIndexNumeric" Minimum="0" Maximum="255" Width="110"/>
                        <Button x:Name="SetActiveButton" Content="Set Active" Width="110"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="5">
                        <TextBlock Text="Active MAC" FontWeight="Bold"/>
                        <TextBlock x:Name="ActiveMacDisplayLabel" Text="Active MAC: (unknown)"
                                   FontFamily="Consolas" FontSize="14"/>
                        <TextBlock Text="MACACTIVE responses update this display. Range and active index persist on the ground unit." FontStyle="Italic" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Throttle">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="Configure piecewise linear throttle output mapping. Input ranges map to output ranges sent to the car." FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Spacing="8">
                        <TextBlock Text="Throttle Mapping Ranges" FontWeight="Bold"/>
                        <ListBox x:Name="ThrottleMappingListBox" Height="200" SelectionMode="Single"/>
                        
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Input Min" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" x:Name="NewInputMinTextBox" Text="0" Width="120"/>
                            <TextBlock Grid.Column="2" Text="Max" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="3" x:Name="NewInputMaxTextBox" Text="180" Width="120"/>
                            <TextBlock Grid.Column="4" Text="→ Output Min" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox Grid.Column="5" x:Name="NewOutputMinTextBox" Text="0" Width="120"/>
                            <TextBlock Grid.Column="6" Text="Max" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="7" x:Name="NewOutputMaxTextBox" Text="180" Width="120"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button x:Name="AddMappingButton" Content="Add Range" Width="100"/>
                            <Button x:Name="RemoveMappingButton" Content="Remove Selected" Width="120"/>
                            <Button x:Name="ClearMappingsButton" Content="Clear All" Width="100"/>
                            <Button x:Name="ResetDefaultMappingButton" Content="Reset to Default (0-180)" Width="160"/>
                        </StackPanel>
                        
                        <TextBlock Text="Ranges are applied in order. Ensure input ranges don't overlap for predictable results." FontStyle="Italic" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Padding="10" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Margin="0,10,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Example Configurations" FontWeight="Bold"/>
                            <TextBlock Text="• Full Range: [0-180] → [0-180]" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Text="• Limited Speed: [0-80] → [40-85], [81-100] → [85-95], [101-180] → [96-110]" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Text="• Reverse Only: [0-90] → [90-90], [91-180] → [60-90]" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Steering">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="Configure piecewise linear steering output mapping." FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Spacing="8">
                        <TextBlock Text="Steering Mapping Ranges" FontWeight="Bold"/>
                        <ListBox x:Name="SteeringMappingListBox" Height="200" SelectionMode="Single"/>
                        
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Input Min" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" x:Name="NewSteeringInputMinTextBox" Text="0" Width="120"/>
                            <TextBlock Grid.Column="2" Text="Max" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="3" x:Name="NewSteeringInputMaxTextBox" Text="180" Width="120"/>
                            <TextBlock Grid.Column="4" Text="→ Output Min" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox Grid.Column="5" x:Name="NewSteeringOutputMinTextBox" Text="0" Width="120"/>
                            <TextBlock Grid.Column="6" Text="Max" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox Grid.Column="7" x:Name="NewSteeringOutputMaxTextBox" Text="180" Width="120"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button x:Name="AddSteeringMappingButton" Content="Add Range" Width="100"/>
                            <Button x:Name="RemoveSteeringMappingButton" Content="Remove Selected" Width="120"/>
                            <Button x:Name="ClearSteeringMappingsButton" Content="Clear All" Width="100"/>
                            <Button x:Name="ResetDefaultSteeringMappingButton" Content="Reset to Default (0-180)" Width="180"/>
                        </StackPanel>
                        
                        <TextBlock Text="Ranges are applied in order to steering output. Keep them non-overlapping." FontStyle="Italic" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Padding="10" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Margin="0,10,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Example Configurations" FontWeight="Bold"/>
                            <TextBlock Text="• Full Range: [0-180] → [0-180]" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Text="• Clip extremes: [0-20] → [10-20], [20-160] → [20-160], [160-180] → [160-170]" FontFamily="Consolas" FontSize="11"/>
                            <TextBlock Text="• Soften center: [70-110] → [80-100], others map normally" FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Logs">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Debug Log" FontWeight="Bold" Margin="0,0,0,5"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="LogTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                </ScrollViewer>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
